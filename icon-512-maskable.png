/* ============================================================
   Onco-RT — Sistema de diseño
   Motivo: isocentro / curvas de isodosis (haces convergiendo
   en un punto, bandas de color frío→cálido como en los mapas
   de dosis de los sistemas de planificación).
   ============================================================ */

@import url("https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=IBM+Plex+Sans:wght@400;500;600&family=IBM+Plex+Mono:wght@500;600&display=swap");

:root {
  /* Color */
  --bg: #F7F9FB;
  --surface: #FFFFFF;
  --ink: #14202E;
  --ink-soft: #51626F;
  --ink-faint: #8696A3;
  --line: #DCE3E8;
  --line-soft: #EAEFF2;

  --primary: #0B5E73;
  --primary-dark: #073C49;
  --primary-tint: #E4F0F2;

  --accent-cool: #4FA9C9;
  --accent-warm: #E8743B;
  --accent-warm-tint: #FCEAE0;

  /* Color por módulo (escala fría → cálida, como las isodosis) */
  --mod-1: #2E86AB;
  --mod-1-tint: #E7F1F6;
  --mod-2: #1B8A6B;
  --mod-2-tint: #E5F4EF;
  --mod-3: #E8743B;
  --mod-3-tint: #FCEAE0;
  --mod-4: #C23B5C;
  --mod-4-tint: #FAE6EB;

  /* Tipografía */
  --font-display: "Space Grotesk", "IBM Plex Sans", sans-serif;
  --font-body: "IBM Plex Sans", system-ui, sans-serif;
  --font-mono: "IBM Plex Mono", ui-monospace, monospace;

  /* Layout */
  --radius-s: 8px;
  --radius-m: 14px;
  --radius-l: 22px;
  --shadow-card: 0 1px 2px rgba(20, 32, 46, 0.04), 0 8px 24px -16px rgba(20, 32, 46, 0.18);
  --nav-h: 64px;
  --header-h: 56px;
  --max-w: 720px;
}

* { box-sizing: border-box; }

html, body {
  margin: 0;
  padding: 0;
  background: var(--bg);
  color: var(--ink);
  font-family: var(--font-body);
  -webkit-font-smoothing: antialiased;
}

body {
  min-height: 100vh;
  padding-bottom: calc(var(--nav-h) + 12px);
}

#app {
  max-width: var(--max-w);
  margin: 0 auto;
  position: relative;
}

img, svg { display: block; max-width: 100%; }

a { color: inherit; }

button {
  font-family: inherit;
  cursor: pointer;
  border: none;
  background: none;
  color: inherit;
}

:focus-visible {
  outline: 2px solid var(--primary);
  outline-offset: 2px;
}

@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.001ms !important;
    transition-duration: 0.001ms !important;
  }
}

/* ---------- Header ---------- */

.app-header {
  position: sticky;
  top: 0;
  z-index: 20;
  height: var(--header-h);
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 0 16px;
  background: var(--bg);
  border-bottom: 1px solid var(--line);
}

.back-btn {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--radius-s);
  color: var(--ink-soft);
  flex-shrink: 0;
}
.back-btn:hover { background: var(--line-soft); color: var(--ink); }
.back-btn[hidden] { display: none; }

.app-header h1 {
  font-family: var(--font-display);
  font-size: 16px;
  font-weight: 600;
  margin: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.header-mark {
  width: 28px;
  height: 28px;
  flex-shrink: 0;
}

/* ---------- Mark / logo (isocentro) ---------- */

.iso-mark circle.ring { fill: none; stroke-width: 2.4; }
.iso-mark .r1 { stroke: var(--accent-cool); }
.iso-mark .r2 { stroke: #fff; }
.iso-mark .r3 { stroke: var(--accent-warm); }
.iso-mark .core { fill: #fff; }
.iso-mark .bg { fill: var(--primary); }

/* ---------- Pantallas (vistas) ---------- */

.screen {
  padding: 18px 16px 8px;
  animation: fade-up 0.28s ease both;
}
.screen[hidden] { display: none; }

@keyframes fade-up {
  from { opacity: 0; transform: translateY(6px); }
  to { opacity: 1; transform: translateY(0); }
}

/* ---------- Home / hero ---------- */

.hero {
  background: linear-gradient(135deg, var(--primary-dark), var(--primary) 70%);
  border-radius: var(--radius-l);
  padding: 22px 20px 20px;
  color: #fff;
  position: relative;
  overflow: hidden;
  margin-bottom: 22px;
}

.hero::after {
  content: "";
  position: absolute;
  right: -40px;
  top: -40px;
  width: 180px;
  height: 180px;
  border-radius: 50%;
  border: 1.5px solid rgba(255,255,255,0.18);
  box-shadow: 0 0 0 24px rgba(255,255,255,0.06), 0 0 0 48px rgba(255,255,255,0.03);
}

.hero .eyebrow {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.72);
  margin: 0 0 6px;
}

.hero h2 {
  font-family: var(--font-display);
  font-size: 21px;
  line-height: 1.25;
  margin: 0 0 10px;
  max-width: 30ch;
  position: relative;
}

.hero p {
  margin: 0;
  font-size: 13.5px;
  color: rgba(255,255,255,0.82);
  max-width: 38ch;
  position: relative;
}

/* ---------- Buscador ---------- */

.search-box {
  display: flex;
  align-items: center;
  gap: 8px;
  background: var(--surface);
  border: 1px solid var(--line);
  border-radius: var(--radius-m);
  padding: 11px 14px;
  margin-bottom: 22px;
}
.search-box svg { color: var(--ink-faint); flex-shrink: 0; }
.search-box input {
  border: none;
  outline: none;
  background: none;
  font-family: var(--font-body);
  font-size: 14.5px;
  color: var(--ink);
  width: 100%;
}
.search-box input::placeholder { color: var(--ink-faint); }

/* ---------- Section heading ---------- */

.section-label {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  color: var(--ink-faint);
  margin: 0 2px 10px;
}

/* ---------- Tarjetas de módulo ---------- */

.module-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 12px;
  margin-bottom: 26px;
}

.module-card {
  display: flex;
  align-items: center;
  gap: 14px;
  background: var(--surface);
  border: 1px solid var(--line);
  border-radius: var(--radius-m);
  padding: 14px;
  text-align: left;
  box-shadow: var(--shadow-card);
  transition: transform 0.15s ease, border-color 0.15s ease;
}
.module-card:hover { transform: translateY(-1px); border-color: var(--line-soft); }
.module-card:active { transform: translateY(0); }

.module-card.is-disabled { opacity: 0.55; }
.module-card.is-disabled:hover { transform: none; }

.module-icon {
  width: 46px;
  height: 46px;
  border-radius: var(--radius-s);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.module-icon svg { width: 22px; height: 22px; }

.module-body { flex: 1; min-width: 0; }
.module-body h3 {
  font-family: var(--font-display);
  font-size: 14.5px;
  font-weight: 600;
  margin: 0 0 3px;
}
.module-body p {
  margin: 0;
  font-size: 12.5px;
  color: var(--ink-soft);
  line-height: 1.4;
}

.module-meta {
  font-family: var(--font-mono);
  font-size: 10.5px;
  color: var(--ink-faint);
  margin-top: 6px;
  display: flex;
  align-items: center;
  gap: 6px;
}

.chev { color: var(--ink-faint); flex-shrink: 0; }

.badge-soon {
  font-family: var(--font-mono);
  font-size: 9.5px;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  background: var(--line-soft);
  color: var(--ink-soft);
  padding: 3px 7px;
  border-radius: 999px;
  flex-shrink: 0;
}

/* ---------- Lista de lecciones (vista de módulo) ---------- */

.module-hero {
  border-radius: var(--radius-l);
  padding: 20px;
  margin-bottom: 20px;
  color: #fff;
  position: relative;
  overflow: hidden;
}
.module-hero h2 {
  font-family: var(--font-display);
  font-size: 19px;
  margin: 0 0 6px;
}
.module-hero p {
  margin: 0;
  font-size: 13px;
  color: rgba(255,255,255,0.85);
  max-width: 40ch;
}

.lesson-list {
  list-style: none;
  margin: 0 0 24px;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.lesson-row {
  display: flex;
  align-items: center;
  gap: 12px;
  width: 100%;
  background: var(--surface);
  border: 1px solid var(--line);
  border-radius: var(--radius-m);
  padding: 13px 14px;
  text-align: left;
}

.lesson-num {
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--ink-faint);
  width: 22px;
  flex-shrink: 0;
}

.lesson-row h4 {
  font-family: var(--font-body);
  font-weight: 600;
  font-size: 14px;
  margin: 0 0 2px;
}
.lesson-row .lesson-sub {
  font-size: 12px;
  color: var(--ink-soft);
  margin: 0;
}

/* ---------- Vista de lección ---------- */

.lesson-eyebrow {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  margin: 0 0 8px;
}

.lesson-title {
  font-family: var(--font-display);
  font-size: 22px;
  line-height: 1.3;
  margin: 0 0 18px;
}

.lesson-content { padding-bottom: 12px; }

.lesson-content h3 {
  font-family: var(--font-display);
  font-size: 15.5px;
  margin: 26px 0 10px;
  padding-top: 4px;
  display: flex;
  align-items: baseline;
  gap: 8px;
}

.lesson-content h3::before {
  content: "";
  width: 14px;
  height: 2px;
  background: var(--accent-warm);
  display: inline-block;
  flex-shrink: 0;
}

.lesson-content p {
  font-size: 14.5px;
  line-height: 1.65;
  color: var(--ink);
  margin: 0 0 12px;
}

.lesson-content ul, .lesson-content ol {
  margin: 0 0 14px;
  padding-left: 20px;
}
.lesson-content li {
  font-size: 14.5px;
  line-height: 1.6;
  margin-bottom: 6px;
}

.lesson-content strong { font-weight: 600; }

.callout {
  border-left: 3px solid var(--accent-warm);
  background: var(--accent-warm-tint);
  border-radius: 0 var(--radius-s) var(--radius-s) 0;
  padding: 12px 14px;
  margin: 16px 0;
  font-size: 13.5px;
  line-height: 1.55;
  color: var(--primary-dark);
}
.callout strong { display: block; margin-bottom: 3px; font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.05em; text-transform: uppercase; }

.glossary-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 10px;
  margin: 16px 0 8px;
}
.glossary-item {
  background: var(--surface);
  border: 1px solid var(--line);
  border-radius: var(--radius-s);
  padding: 11px 13px;
}
.glossary-term {
  font-family: var(--font-mono);
  font-size: 12.5px;
  font-weight: 600;
  color: var(--primary);
  margin: 0 0 3px;
}
.glossary-def {
  font-size: 13px;
  color: var(--ink-soft);
  margin: 0;
  line-height: 1.5;
}

.draft-banner {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  background: #FFF6E8;
  border: 1px solid #F0DBAE;
  border-radius: var(--radius-m);
  padding: 12px 14px;
  margin-bottom: 20px;
  font-size: 12.5px;
  line-height: 1.5;
  color: #6B4A14;
}
.draft-banner svg { flex-shrink: 0; margin-top: 1px; color: #B5821C; }

.lesson-nav {
  display: flex;
  justify-content: space-between;
  gap: 10px;
  margin-top: 28px;
  padding-top: 18px;
  border-top: 1px solid var(--line);
}
.lesson-nav-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 3px;
  padding: 12px 14px;
  border: 1px solid var(--line);
  border-radius: var(--radius-s);
  background: var(--surface);
  min-width: 0;
}
.lesson-nav-btn .dir {
  font-family: var(--font-mono);
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: var(--ink-faint);
}
.lesson-nav-btn .ttl {
  font-size: 12.5px;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.lesson-nav-btn.next { text-align: right; align-items: flex-end; }
.lesson-nav-btn[hidden] { visibility: hidden; }

/* ---------- Resultados de búsqueda ---------- */

.search-result {
  display: block;
  width: 100%;
  text-align: left;
  background: var(--surface);
  border: 1px solid var(--line);
  border-radius: var(--radius-m);
  padding: 13px 14px;
  margin-bottom: 10px;
}
.search-result .res-mod {
  font-family: var(--font-mono);
  font-size: 10px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  margin-bottom: 4px;
}
.search-result h4 { margin: 0 0 3px; font-size: 14px; font-weight: 600; }
.search-result p { margin: 0; font-size: 12.5px; color: var(--ink-soft); line-height: 1.45; }
mark { background: #FCE7A8; color: inherit; border-radius: 2px; padding: 0 1px; }

.empty-state {
  text-align: center;
  padding: 50px 20px;
  color: var(--ink-faint);
}
.empty-state svg { margin: 0 auto 12px; opacity: 0.6; }
.empty-state p { font-size: 13.5px; margin: 0; }

/* ---------- Bottom nav ---------- */

.bottom-nav {
  position: fixed;
  left: 50%;
  transform: translateX(-50%);
  bottom: 0;
  width: 100%;
  max-width: var(--max-w);
  height: var(--nav-h);
  background: rgba(255,255,255,0.95);
  backdrop-filter: saturate(180%) blur(10px);
  border-top: 1px solid var(--line);
  display: flex;
  z-index: 30;
}

.nav-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 3px;
  color: var(--ink-faint);
}
.nav-btn svg { width: 21px; height: 21px; }
.nav-btn span { font-size: 10.5px; font-weight: 500; }
.nav-btn.is-active { color: var(--primary); }

/* ---------- Utilidades responsive ---------- */

@media (min-width: 560px) {
  .module-grid { grid-template-columns: 1fr 1fr; }
  .glossary-grid { grid-template-columns: 1fr 1fr; }
}

@media (min-width: 760px) {
  body { padding-bottom: 24px; }
  .bottom-nav { display: none; }
  .app-header { padding: 0 24px; }
  #app { padding: 0; }
  .screen { padding: 26px 24px 40px; }
}
